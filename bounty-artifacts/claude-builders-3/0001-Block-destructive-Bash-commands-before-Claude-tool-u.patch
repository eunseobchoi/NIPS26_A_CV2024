+#!/usr/bin/env python3
+from __future__ import annotations
+
+import importlib.util
+import json
+import subprocess
+import sys
+import tempfile
+import unittest
+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[1]
+HOOK = ROOT / ".claude" / "hooks" / "block-destructive-bash.py"
+
+
+spec = importlib.util.spec_from_file_location("block_destructive_bash", HOOK)
+module = importlib.util.module_from_spec(spec)
+assert spec.loader is not None
+spec.loader.exec_module(module)
+
+
+class BlockReasonTests(unittest.TestCase):
+    def test_blocks_required_patterns(self) -> None:
+        cases = [
+            "rm -rf /tmp/example",
+            "rm -fr ./build",
+            "rm -r -f ./dist",
+            "rm --recursive --force ./dist",
+            "git push --force origin main",
+            "git push -f",
+            "mysql -e 'DROP TABLE users'",
+            "psql -c 'TRUNCATE audit_log'",
+            "mysql -e 'DELETE FROM users'",
+        ]
+        for command in cases:
+            with self.subTest(command=command):
+                self.assertIsNotNone(module.block_reason(command))
+
+    def test_allows_normal_commands(self) -> None:
+        cases = [
+            "ls -la",
+            "rm -ri ./build",
+            "git push origin main",
+            "mysql -e 'DELETE FROM users WHERE id = 1'",
+            "python3 -m unittest",
+        ]
+        for command in cases:
+            with self.subTest(command=command):
+                self.assertIsNone(module.block_reason(command))
+
+    def test_non_bash_payload_is_ignored(self) -> None:
+        self.assertIsNone(module.handle_payload({"tool_name": "Read", "tool_input": {"file_path": "README.md"}}))
+
+    def test_denied_command_logs_and_returns_claude_hook_decision(self) -> None:
+        payload = {
+            "tool_name": "Bash",
+            "tool_input": {"command": "rm -rf ./dist"},
+            "cwd": "/workspace/project",
+        }
+        with tempfile.TemporaryDirectory() as home:
+            process = subprocess.run(
+                [sys.executable, str(HOOK)],
+                input=json.dumps(payload),
+                text=True,
+                stdout=subprocess.PIPE,
+                stderr=subprocess.PIPE,
+                check=True,
+                env={"HOME": home, "PATH": "/usr/bin:/bin"},
+            )
+
+            decision = json.loads(process.stdout)
+            output = decision["hookSpecificOutput"]
+            self.assertEqual(output["hookEventName"], "PreToolUse")
+            self.assertEqual(output["permissionDecision"], "deny")
+            self.assertIn("rm -rf", output["permissionDecisionReason"])
+
+            log_path = Path(home) / ".claude" / "hooks" / "blocked.log"
+            log_entry = json.loads(log_path.read_text(encoding="utf-8").strip())
+            self.assertEqual(log_entry["attempted_command"], "rm -rf ./dist")
+            self.assertEqual(log_entry["project_path"], "/workspace/project")
+
+
+if __name__ == "__main__":
+    unittest.main()
