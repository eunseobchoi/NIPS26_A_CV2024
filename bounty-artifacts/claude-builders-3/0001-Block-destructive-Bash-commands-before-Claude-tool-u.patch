+#!/usr/bin/env python3
+"""Claude Code PreToolUse hook that blocks destructive Bash commands."""
+
+from __future__ import annotations
+
+import json
+import os
+import re
+import shlex
+import sys
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any
+
+
+LOG_PATH = Path.home() / ".claude" / "hooks" / "blocked.log"
+
+
+def _compact_command(command: str) -> str:
+    return " ".join(command.replace("\n", " ").split())
+
+
+def _split_command(command: str) -> list[str]:
+    try:
+        return shlex.split(command, posix=True)
+    except ValueError:
+        return command.split()
+
+
+def _has_rm_rf(command: str) -> bool:
+    tokens = _split_command(command)
+    for index, token in enumerate(tokens):
+        if token != "rm":
+            continue
+        recursive = False
+        force = False
+        for arg in tokens[index + 1 :]:
+            if arg == "--":
+                break
+            lower_arg = arg.lower()
+            if lower_arg in {"--recursive", "--dir"}:
+                recursive = True
+            if lower_arg == "--force":
+                force = True
+            if arg.startswith("-") and not lower_arg.startswith("--"):
+                recursive = recursive or "r" in lower_arg
+                force = force or "f" in lower_arg
+            if recursive and force:
+                return True
+    return bool(re.search(r"(^|[;&|]\s*)rm\s+[^\n;|&]*(?:-[A-Za-z]*r[A-Za-z]*f|-[A-Za-z]*f[A-Za-z]*r|--recursive[^\n;|&]*--force|--force[^\n;|&]*--recursive)", command, re.IGNORECASE))
+
+
+def _has_force_push(command: str) -> bool:
+    tokens = _split_command(command)
+    for index, token in enumerate(tokens):
+        if token != "git":
+            continue
+        rest = tokens[index + 1 :]
+        if not rest or rest[0] != "push":
+            continue
+        for arg in rest[1:]:
+            if arg in {"--force", "-f"} or arg.startswith("--force="):
+                return True
+            if arg.startswith("--force-with-lease"):
+                return True
+    return bool(re.search(r"(^|[;&|]\s*)git\s+push\b[^\n;|&]*(--force(?:=|\b)|--force-with-lease\b|\s-f\b)", command))
+
+
+def _sql_statements(command: str) -> list[str]:
+    # Good enough for shell-hook guarding: split obvious SQL batches without
+    # trying to parse a full shell or SQL grammar.
+    return [statement.strip() for statement in re.split(r";|\n", command) if statement.strip()]
+
+
+def _has_delete_without_where(command: str) -> bool:
+    for statement in _sql_statements(command):
+        match = re.search(r"\bDELETE\s+FROM\b", statement, re.IGNORECASE)
+        if not match:
+            continue
+        tail = statement[match.end() :]
+        if not re.search(r"\bWHERE\b", tail, re.IGNORECASE):
+            return True
+    return False
+
+
+def block_reason(command: str) -> str | None:
+    checks = [
+        (_has_rm_rf, "contains rm -rf, which can recursively delete files"),
+        (_has_force_push, "contains git push --force, which can rewrite remote history"),
+        (lambda value: bool(re.search(r"\bDROP\s+TABLE\b", value, re.IGNORECASE)), "contains DROP TABLE"),
+        (lambda value: bool(re.search(r"\bTRUNCATE\b", value, re.IGNORECASE)), "contains TRUNCATE"),
+        (_has_delete_without_where, "contains DELETE FROM without a WHERE clause"),
+    ]
+    for predicate, reason in checks:
+        if predicate(command):
+            return reason
+    return None
+
+
+def _project_path(payload: dict[str, Any]) -> str:
+    for key in ("cwd", "project_path", "workspace", "workspace_dir"):
+        value = payload.get(key)
+        if isinstance(value, str) and value:
+            return value
+    return os.getcwd()
+
+
+def _attempted_command(payload: dict[str, Any]) -> str | None:
+    if payload.get("tool_name") != "Bash":
+        return None
+    tool_input = payload.get("tool_input")
+    if not isinstance(tool_input, dict):
+        return None
+    command = tool_input.get("command")
+    return command if isinstance(command, str) else None
+
+
+def _log_blocked(command: str, project_path: str, reason: str) -> None:
+    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
+    timestamp = datetime.now(timezone.utc).isoformat()
+    entry = {
+        "timestamp": timestamp,
+        "attempted_command": command,
+        "project_path": project_path,
+        "reason": reason,
+    }
+    with LOG_PATH.open("a", encoding="utf-8") as log_file:
+        log_file.write(json.dumps(entry, ensure_ascii=False) + "\n")
+
+
+def _deny(reason: str, command: str) -> dict[str, Any]:
+    compact = _compact_command(command)
+    message = f"Blocked destructive Bash command: {reason}. Command: {compact}"
+    return {
+        "hookSpecificOutput": {
+            "hookEventName": "PreToolUse",
+            "permissionDecision": "deny",
+            "permissionDecisionReason": message,
+        }
+    }
+
+
+def handle_payload(payload: dict[str, Any]) -> dict[str, Any] | None:
+    command = _attempted_command(payload)
+    if command is None:
+        return None
+
+    reason = block_reason(command)
+    if reason is None:
+        return None
+
+    _log_blocked(command, _project_path(payload), reason)
+    return _deny(reason, command)
+
+
+def main() -> int:
+    try:
+        payload = json.load(sys.stdin)
+    except json.JSONDecodeError:
+        return 0
+
+    if not isinstance(payload, dict):
+        return 0
+
+    decision = handle_payload(payload)
+    if decision is None:
+        return 0
+
+    print(json.dumps(decision))
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
