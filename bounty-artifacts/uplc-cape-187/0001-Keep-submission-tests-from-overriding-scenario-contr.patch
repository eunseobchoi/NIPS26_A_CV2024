   TEST_TMP_DIR="$(cape_mktemp_dir)"
@@ -280,6 +348,8 @@ main() {
     "verify help" "(cd \"$PROJECT_ROOT\" && PROJECT_ROOT=\"$SANDBOX_DIR\" bash \"$REPO_ROOT/scripts/cape-subcommands/submission/verify.sh\" --help)" 5 "" \
     "measure help" "(cd \"$PROJECT_ROOT\" && PROJECT_ROOT=\"$SANDBOX_DIR\" bash \"$REPO_ROOT/scripts/cape-subcommands/submission/measure.sh\" --help)" 5 ""
 
+  run_submission_tests_file_regression
+
   # Schema validation error reporting tests
   test_group "schema validation error reporting" \
     "create test submission for schema errors" \
diff --git a/scripts/lib/cape_common.sh b/scripts/lib/cape_common.sh
index 204c512..d7f0968 100755
--- a/scripts/lib/cape_common.sh
+++ b/scripts/lib/cape_common.sh
@@ -156,6 +156,19 @@ cape_relpath() {
   fi
 }
 
+cape_reject_submission_tests_file() {
+  local submission_dir="$1"
+  local submission_tests="$submission_dir/cape-tests.json"
+
+  if [[ -f "$submission_tests" ]]; then
+    cape_error "Submission-local cape-tests.json is not allowed: $(cape_relpath "$submission_tests")"
+    cape_error "Tests are part of the scenario contract; use scenarios/<scenario>/cape-tests.json."
+    return 1
+  fi
+
+  return 0
+}
+
