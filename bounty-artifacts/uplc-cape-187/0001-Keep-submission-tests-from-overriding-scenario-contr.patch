diff --git a/scripts/cape-subcommands/test/test.sh b/scripts/cape-subcommands/test/test.sh
index 0d4745a..c30081d 100755
--- a/scripts/cape-subcommands/test/test.sh
+++ b/scripts/cape-subcommands/test/test.sh
@@ -162,6 +162,74 @@ run_uplc_validation() {
   fi
 }
 
+run_submission_tests_file_regression() {
+  if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
+    echo -e "\033[0;34mINFO:\033[0m Testing submission-local cape-tests.json rejection..."
+  else
+    echo "INFO: Testing submission-local cape-tests.json rejection..."
+  fi
+
+  local fixture="$SANDBOX_DIR/submissions/fibonacci/Scalus_0.12.1_Unisay"
+  local local_tests="$fixture/cape-tests.json"
+  local stub_bin="$TEST_TMP_DIR/security-stub-bin"
+  local marker="$TEST_TMP_DIR/measure-was-called"
+
+  mkdir -p "$stub_bin"
+  cat > "$stub_bin/cabal" <<'EOF'
+#!/usr/bin/env bash
+exit 0
+EOF
+  cat > "$stub_bin/check-jsonschema" <<'EOF'
+#!/usr/bin/env bash
+printf '{"status":"ok","errors":[]}\n'
+EOF
+  cat > "$stub_bin/measure" <<EOF
+#!/usr/bin/env bash
+touch "$marker"
+exit 99
+EOF
+  chmod +x "$stub_bin/cabal" "$stub_bin/check-jsonschema" "$stub_bin/measure"
+
+  printf '{"tests":[]}\n' > "$local_tests"
+
+  local output_file
+  output_file="$(cape_mktemp)"
+
+  TESTS_RUN=$((TESTS_RUN + 1))
+  rm -f "$marker"
+  if PATH="$stub_bin:$PATH" PROJECT_ROOT="$SANDBOX_DIR" bash "$REPO_ROOT/scripts/cape-subcommands/submission/verify.sh" "$fixture" > "$output_file" 2>&1; then
+    echo "ERROR: ✗ verify rejects submission-local cape-tests.json"
+    echo "  Expected: failure (non-zero)"
+    TESTS_FAILED=$((TESTS_FAILED + 1))
+  elif grep -q "Submission-local cape-tests.json is not allowed" "$output_file" && [[ ! -e "$marker" ]]; then
+    echo "INFO: ✓ verify rejects submission-local cape-tests.json"
+    TESTS_PASSED=$((TESTS_PASSED + 1))
+  else
+    echo "ERROR: ✗ verify rejects submission-local cape-tests.json"
+    echo "  Output:"
+    sed 's/^/    /' "$output_file"
+    TESTS_FAILED=$((TESTS_FAILED + 1))
+  fi
+
+  TESTS_RUN=$((TESTS_RUN + 1))
+  rm -f "$marker"
+  if PATH="$stub_bin:$PATH" PROJECT_ROOT="$SANDBOX_DIR" bash "$REPO_ROOT/scripts/cape-subcommands/submission/measure.sh" "$fixture" > "$output_file" 2>&1; then
+    echo "ERROR: ✗ measure rejects submission-local cape-tests.json"
+    echo "  Expected: failure (non-zero)"
+    TESTS_FAILED=$((TESTS_FAILED + 1))
+  elif grep -q "Submission-local cape-tests.json is not allowed" "$output_file" && [[ ! -e "$marker" ]]; then
+    echo "INFO: ✓ measure rejects submission-local cape-tests.json"
+    TESTS_PASSED=$((TESTS_PASSED + 1))
+  else
+    echo "ERROR: ✗ measure rejects submission-local cape-tests.json"
+    echo "  Output:"
+    sed 's/^/    /' "$output_file"
+    TESTS_FAILED=$((TESTS_FAILED + 1))
+  fi
+
+  rm -f "$local_tests" "$marker" "$output_file"
+}
