diff --git a/node/utxo_endpoints.py b/node/utxo_endpoints.py
index b19e8ff..257f1ac 100644
--- a/node/utxo_endpoints.py
+++ b/node/utxo_endpoints.py
@@ -96,6 +96,16 @@ def _ensure_signed_float_preserves_nrtc(amount: Decimal, nrtc: int,
             f"{field_name} cannot be represented safely in signed payload"
         )
 
+
+def _optional_text_field(data: dict, field_name: str) -> str:
+    """Return a stripped text field or raise ValueError on hostile JSON shapes."""
+    raw = data.get(field_name)
+    if raw is None:
+        return ''
+    if not isinstance(raw, str):
+        raise ValueError(f"{field_name} must be a string")
+    return raw.strip()
+
