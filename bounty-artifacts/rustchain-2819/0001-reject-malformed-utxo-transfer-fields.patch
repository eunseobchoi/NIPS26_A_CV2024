+            'amount_rtc': 1.0,
+            'public_key': 'aabbccdd' * 8,
+            'signature': 'sig' * 22,
+            'nonce': 123,
+        }
+        cases = {
+            'from_address': ['not', 'string'],
+            'to_address': {'addr': 'bob'},
+            'public_key': 123,
+            'signature': True,
+        }
+        for field, value in cases.items():
+            with self.subTest(field=field):
+                payload = dict(base)
+                payload[field] = value
+                r = self.client.post('/utxo/transfer', json=payload)
+                self.assertEqual(r.status_code, 400)
+                body = r.get_json()
+                self.assertEqual(body['code'], 'INVALID_FIELD_TYPE')
+                self.assertIn(field, body['error'])
