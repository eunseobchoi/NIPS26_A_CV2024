# Copy this file to configs/paths.env and adjust to your local paths.
# Source it with `source configs/paths.env` before running any script.

# Root of the CV2024 public dataset (expects Dataset/training/<class>/<source>/ and Dataset/validation/)
# Download: https://figshare.com/articles/dataset/Training_and_Validation_Dataset_of_Capsule_Vision_2024_Challenge/26403469
# Cite: Handa et al. 2024 (Capsule Vision 2024 Challenge), CC-BY 4.0.
export CV2024_ROOT=/path/to/cv2024/Dataset

# Root of the Kvasir-Capsule corpus (expects labelled_images/<class>/ and the official 2-fold CSV)
# Download: https://osf.io/dv2ag/ (DOI: 10.17605/OSF.IO/DV2AG)
# Cite: Smedsrud et al. 2021 (Kvasir-Capsule, Scientific Data 8:142), CC-BY 4.0.
export KVASIR_ROOT=/path/to/Kvasir-Capsule

# Optional: HF cache for DINOv2 weights
export HF_HOME="$HOME/.cache/huggingface"

# Optional: GPU selection
# export CUDA_VISIBLE_DEVICES=0
